    "title": "Rumours in the Courtyard",
    "milestone": false,
    "story": "Whispers circulate that a concubine in the eastern wing has been poisoning rivals. Your alliance partner pulls you aside — your name has been mentioned.",
    "choices": [
      { "label": "Go directly to the head eunuch to clear your name", "consequences": { "compassion": 0, "suspicion": -1, "money": -5, "health": 0, "beauty": 0 }, "result": "The eunuch vouches for you, but the visit costs a bribe." },
      { "label": "Lay low and wait for the rumour to die", "consequences": { "compassion": 0, "suspicion": 1, "money": 0, "health": 0, "beauty": 0 }, "result": "The rumour lingers longer than you hoped." },
      { "label": "Find out who started the rumour", "consequences": { "compassion": -1, "suspicion": 0, "money": 0, "health": -1, "beauty": 0 }, "result": "You uncover the source, but the hunt exhausts you." }
