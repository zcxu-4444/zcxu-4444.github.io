[
  {
    "year": 1, "age": 16,
    "title": "Year 1: Yingluo enters the Forbidden Palace",
    "milestone": true,
    "story": "You are escorted through the vermillion gates for the first time. You are younger than most of the other maids — sixteen years old, and already the palace feels like a maze with no exit. Another embroidery maid whispers a warning as you pass: someone here already wants you gone.",
    "choices": [
      { "label": "Thank her and ask her name", "consequences": { "compassion": 1, "suspicion": 0, "money": 0, "health": 0, "beauty": 0 }, "result": "She smiles cautiously. You may have made your first friend." },
      { "label": "Stay quiet and keep walking", "consequences": { "compassion": 0, "suspicion": -1, "money": 0, "health": 0, "beauty": 0 }, "result": "You reveal nothing. A wise first move." },
      { "label": "Report the whisper to the head maid", "consequences": { "compassion": -1, "suspicion": 1, "money": 5, "health": 0, "beauty": 0 }, "result": "The head maid rewards you with a small coin, but the other maids notice." }
    ],
    "prep_options": ["food", "health", "beauty", "savings"],
    "alliance_pool": ["senior_eunuch", "fellow_maid", "none"]
  },
  {
    "year": 2, "age": 17,
    "title": "The Stolen Embroidery",
    "milestone": false,
    "story": "A piece of embroidery you spent weeks on has gone missing from the workshop. The head maid is furious and demands to know who is responsible.",
    "choices": [
      { "label": "Accuse the maid you suspect", "consequences": { "compassion": -1, "suspicion": 1, "money": 0, "health": 0, "beauty": 0 }, "result": "The accused maid is punished, but you have made an enemy." },
      { "label": "Take the blame yourself", "consequences": { "compassion": 1, "suspicion": 0, "money": -10, "health": -1, "beauty": 0 }, "result": "You are fined and made to redo the work. Others are quietly grateful." },
      { "label": "Investigate quietly before saying anything", "consequences": { "compassion": 0, "suspicion": 0, "money": 0, "health": 0, "beauty": 1 }, "result": "You find the thief yourself and handle it discreetly. Your reputation grows." }
    ],
    "prep_options": ["food", "health", "savings", "charity"],
    "alliance_pool": ["senior_eunuch", "fellow_maid", "none"]
  },
  {
    "year": 3, "age": 18,
    "title": "A Noble Lady's Favor",
    "milestone": false,
    "story": "A high-ranking noble lady visits the embroidery workshop and takes notice of your work. She invites you to embroider a personal gift for the Emperor.",
    "choices": [
      { "label": "Accept eagerly and work your hardest", "consequences": { "compassion": 0, "suspicion": 1, "money": 20, "health": -1, "beauty": 0 }, "result": "Your work impresses everyone, but rivals grow jealous." },
      { "label": "Accept humbly and dedicate it to her household", "consequences": { "compassion": 1, "suspicion": 0, "money": 10, "health": 0, "beauty": 1 }, "result": "She is touched. You gain a small but genuine ally." },
      { "label": "Politely decline, citing your low station", "consequences": { "compassion": 0, "suspicion": -1, "money": 0, "health": 0, "beauty": 0 }, "result": "She respects your modesty. You remain below the radar." }
    ],
    "prep_options": ["food", "health", "beauty", "palace_maintenance"],
    "alliance_pool": ["noble_lady", "senior_eunuch", "none"]
  },
  {
